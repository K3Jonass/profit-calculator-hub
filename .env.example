# --- ProfitHub Web App ---
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
INDEXNOW_KEY=your-indexnow-key

# Site URL (optional). Defaults: http://localhost:3000 in dev, https://profithub.cloud in production.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AI generation (server-side only) ---
OPENAI_API_KEY=your-openai-api-key

# --- ChatGPT App / MCP layer ---
# Optional but recommended for production. If set, callers must send:
# Authorization: Bearer <MCP_SERVER_TOKEN>
MCP_SERVER_TOKEN=replace-with-strong-random-token
